# Netlify _headers — applied to every response from faulhaber.co.uk

/*
  # Tell all crawlers and search engines not to index or follow links
  X-Robots-Tag: noindex, nofollow, noarchive, nosnippet

  # Prevent clickjacking (page can't be embedded in iframes)
  X-Frame-Options: DENY

  # Prevent MIME-type sniffing
  X-Content-Type-Options: nosniff

  # Don't leak referrer info to third parties
  Referrer-Policy: strict-origin-when-cross-origin

  # Disable browser features that aren't needed
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=()

  # Basic XSS protection for older browsers
  X-XSS-Protection: 1; mode=block
